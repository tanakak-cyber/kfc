APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# サブディレクトリで動かす例: https://example.com/kfc （末尾スラッシュなし）
# 画像・ルートURLがずれる場合は true（リバプロで Request の base が取れないとき）
# APP_FORCE_ROOT_URL=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# log = 実際のメールは送らず storage/logs/laravel.log に記録のみ（ローカル開発向け）
#
# ローカルで「送ったメールをブラウザで確認」する例（Mailpit / MailHog 等を PC で起動してから）:
#   MAIL_MAILER=smtp
#   MAIL_HOST=127.0.0.1
#   MAIL_PORT=1025
#   MAIL_USERNAME=null
#   MAIL_PASSWORD=null
#   （Mailpit の Web UI は通常 http://127.0.0.1:8025）
#
# 実アドレスに届けたい例（Gmail 等）: 各サービスの SMTP + アプリパスワード / API キーを MAIL_* に設定
#
# ConoHa（MEO と同じ）:
#   MAIL_MAILER=smtp
#   MAIL_HOST=mail73.conoha.ne.jp
#   MAIL_PORT=587
#   MAIL_USERNAME=info@example.com
#   MAIL_PASSWORD=（パネルで発行したパスワード）
#   MAIL_ENCRYPTION=tls
#   MAIL_FROM_ADDRESS=上記と同じアドレス
#
# 本番・送信専用でよい場合（受信メールボックスは不要）:
#   - From は例: info@fishing-tournament.net（表示用）。実際の SMTP 認証は利用サービスの案内どおり
#     （Amazon SES / SendGrid / Mailgun / Postmark / Resend 等の API または SMTP、
#      またはレンタルサーバの「送信専用 SMTP」）
#   - Laravel は MAIL_MAILER=smtp + MAIL_HOST/PORT/USER/PASS か、ses / postmark / resend 等を選択
#   - DNS: 利用サービスが指示する SPF（TXT）と DKIM（TXT/CNAME）を追加（受信の MX は送信専用なら必須ではない）
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@fishing-tournament.net"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
